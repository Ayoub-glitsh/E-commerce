# Configuration de la base de données PostgreSQL (Neon DB ou local)

# === NEON DB (Recommandé pour production) ===
# Remplacez par votre vraie chaîne de connexion Neon
DB_HOST=your-endpoint.aws.neon.tech
DB_PORT=5432
DB_NAME=your_database_name
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_SSL=true

# === PostgreSQL Local (Développement) ===
# Décommentez pour utiliser PostgreSQL local
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ecommerce_dev
# DB_USERNAME=postgres
# DB_PASSWORD=your_local_password
# DB_SSL=false

# Base de données de test
DB_NAME_TEST=ecommerce_test

# Configuration JWT (pour le module auth)
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Configuration du serveur
NODE_ENV=development
PORT=3000

# URL Prisma complète (utilisée par Prisma Client)
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://your_username:your_password@your-endpoint.aws.neon.tech/your_database_name?sslmode=require"